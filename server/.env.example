# BlinkPay API credentials (from BlinkPay Merchant Portal)
# https://merchants.blinkpay.co.nz/settings/api
#
# IMPORTANT: You must also add blinkpaydemo://callback as a redirect URI
# in the Merchant Portal under Settings > API. The app sends this URI in
# consent requests so BlinkPay knows where to redirect the user after
# bank authorisation.
BLINKPAY_API_URL=sandbox.debit.blinkpay.co.nz
BLINKPAY_CLIENT_ID=<your_client_id>
BLINKPAY_CLIENT_SECRET=<your_client_secret>

# Static API key for app-to-server authentication.
# Generate a random key, e.g.: openssl rand -hex 32
#
# DEMO ONLY: In production, use proper authentication (OAuth2, JWT, etc.)
# This key demonstrates the *pattern* of securing the connection between
# your mobile app and your backend server.
APP_API_KEY=<generate_a_random_key>

# Server configuration (optional)
SERVER_PORT=4567
